    {"id":"sys-status-merge","type":"join","z":"tab-dashboard","name":"merge 3","mode":"custom","build":"array","property":"payload","propertyType":"msg","key":"topic","joiner":"\\n","joinerType":"str","accumulate":false,"timeout":"5","count":"3","reduceRight":false,"reduceExp":"","reduceInit":"","reduceInitType":"","reduceFixup":"","x":730,"y":1040,"wires":[["sys-status-format"]]},
    {"id":"sys-status-format","type":"function","z":"tab-dashboard","name":"Format status","func":"// msg.payload is array of 3 responses [mcp, hue, ccu]\n// Each has statusCode (200 = ok, or undefined/error)\nconst results = msg.payload || [];\nconst now = new Date().toLocaleTimeString('de-DE', {hour:'2-digit', minute:'2-digit', second:'2-digit'});\n\nfunction check(resp, i) {\n    if (resp && resp.statusCode && resp.statusCode >= 200 && resp.statusCode < 400) {\n        return { status: 'online', code: resp.statusCode };\n    }\n    return { status: 'offline', code: resp ? resp.statusCode || 'err' : 'err' };\n}\n\n// Node-RED is always online if this flow is running\nconst nodered = { status: 'online' };\nconst mcp = check(results[0], 0);\nconst hue = check(results[1], 1);\nconst ccu = check(results[2], 2);\n\nmsg.payload = {\n    timestamp: now,\n    services: {\n        nodered: nodered,\n        mcp: mcp\n    },\n    devices: {\n        hue: hue,\n        ccu: ccu\n    }\n};\nreturn msg;","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":890,"y":1040,"wires":[["sys-status-widget","sys-devices-widget"]]},
    {"id":"sys-status-widget","type":"ui-template","z":"tab-dashboard","group":"ui-group-status","name":"Service Status","order":1,"width":"6","height":"1","head":"","format":"<template>\n  <div style=\"padding:4px 0;\">\n    <div v-for=\"(svc, name) in msg?.payload?.services\" :key=\"name\"\n         style=\"display:flex; align-items:center; gap:10px; padding:6px 0;\n                border-bottom:1px solid rgba(148,163,184,0.15);\">\n      <div :style=\"{\n        width:'10px', height:'10px', borderRadius:'50%',\n        background: svc.status === 'online' ? '#22c55e' : '#ef4444',\n        boxShadow: svc.status === 'online' ? '0 0 6px #22c55e' : '0 0 6px #ef4444'\n      }\"></div>\n      <span style=\"color:#e5e7eb; font-size:0.85rem; font-weight:500; min-width:120px;\">\n        {{ name === 'nodered' ? 'Node-RED' : name === 'mcp' ? 'MCP Server' : name }}\n      </span>\n      <span :style=\"{\n        fontSize:'0.7rem', fontWeight:600, letterSpacing:'0.05em', textTransform:'uppercase',\n        padding:'2px 8px', borderRadius:'999px',\n        background: svc.status === 'online' ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)',\n        color: svc.status === 'online' ? '#4ade80' : '#fca5a5',\n        border: svc.status === 'online' ? '1px solid rgba(34,197,94,0.4)' : '1px solid rgba(239,68,68,0.4)'\n      }\">\n        {{ svc.status }}\n      </span>\n    </div>\n    <div style=\"color:#64748b; font-size:0.65rem; padding-top:6px; text-align:right;\">\n      Updated {{ msg?.payload?.timestamp }}\n    </div>\n  </div>\n</template>","storeOutMessages":true,"passthru":false,"resendOnRefresh":true,"templateScope":"local","className":"","x":1070,"y":1020,"wires":[[]]},
    {"id":"sys-devices-widget","type":"ui-template","z":"tab-dashboard","group":"ui-group-devices","name":"Device Connectivity","order":1,"width":"6","height":"1","head":"","format":"<template>\n  <div style=\"padding:4px 0;\">\n    <div v-for=\"(dev, name) in msg?.payload?.devices\" :key=\"name\"\n         style=\"display:flex; align-items:center; gap:10px; padding:6px 0;\n                border-bottom:1px solid rgba(148,163,184,0.15);\">\n      <div :style=\"{\n        width:'10px', height:'10px', borderRadius:'50%',\n        background: dev.status === 'online' ? '#22c55e' : '#ef4444',\n        boxShadow: dev.status === 'online' ? '0 0 6px #22c55e' : '0 0 6px #ef4444'\n      }\"></div>\n      <span style=\"color:#e5e7eb; font-size:0.85rem; font-weight:500; min-width:120px;\">\n        {{ name === 'hue' ? 'Hue Bridge' : name === 'ccu' ? 'Homematic CCU' : name }}\n      </span>\n      <span :style=\"{\n        fontSize:'0.7rem', fontWeight:600, letterSpacing:'0.05em', textTransform:'uppercase',\n        padding:'2px 8px', borderRadius:'999px',\n        background: dev.status === 'online' ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)',\n        color: dev.status === 'online' ? '#4ade80' : '#fca5a5',\n        border: dev.status === 'online' ? '1px solid rgba(34,197,94,0.4)' : '1px solid rgba(239,68,68,0.4)'\n      }\">\n        {{ dev.status }}\n      </span>\n    </div>\n    <div style=\"color:#64748b; font-size:0.65rem; padding-top:6px; text-align:right;\">\n      Updated {{ msg?.payload?.timestamp }}\n    </div>\n  </div>\n</template>","storeOutMessages":true,"passthru":false,"resendOnRefresh":true,"templateScope":"local","className":"","x":1070,"y":1060,"wires":[[]]}
