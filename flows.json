    {"id":"sys-status-check","type":"function","z":"tab-dashboard","name":"Build status requests","func":"// Fan out to check each service/device\n// Output 1: MCP server check\n// Output 2: Hue bridge check\n// Output 3: CCU check\nconst mcp = { url: 'http://localhost:8000/', method: 'GET', requestTimeout: 3000 };\nconst hue = { url: 'http://hue-bridge/api/config', method: 'GET', requestTimeout: 3000 };\nconst ccu = { url: 'http://homematic-ccu/addons/xmlapi/version.cgi', method: 'GET', requestTimeout: 3000 };\nreturn [mcp, hue, ccu];","outputs":3,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":370,"y":1040,"wires":[["sys-mcp-req"],["sys-hue-req"],["sys-ccu-req"]]},
