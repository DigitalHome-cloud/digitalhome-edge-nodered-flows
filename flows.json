    {"id":"dhc-global-css","type":"ui-template","z":"tab-dashboard","page":"","ui":"dhc-ui-base","name":"DHC Global CSS","order":0,"width":0,"height":0,"head":"","format":"/* === DHC Design Language — Global Overrides === */\n\n/* Page background */\n.v-main { background-color: #0f172a !important; }\n\n/* Navigation drawer / sidebar */\n.v-navigation-drawer {\n  background-color: #1e293b !important;\n  border-right: 1px solid rgba(148, 163, 184, 0.3) !important;\n}\n.v-navigation-drawer .v-list-item-title {\n  color: #cbd5f5 !important;\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif !important;\n  font-size: 0.85rem !important;\n}\n.v-navigation-drawer .v-list-item--active {\n  background: rgba(34, 197, 94, 0.12) !important;\n}\n.v-navigation-drawer .v-list-item--active .v-list-item-title {\n  color: #4ade80 !important;\n}\n\n/* App bar / header */\n.v-app-bar {\n  background: rgba(15, 23, 42, 0.9) !important;\n  backdrop-filter: blur(10px) !important;\n  -webkit-backdrop-filter: blur(10px) !important;\n  border-bottom: 1px solid rgba(148, 163, 184, 0.3) !important;\n}\n.v-app-bar .v-toolbar-title { color: #e2e8f0 !important; }\n\n/* Group cards — radial gradient like DHC cards */\n.nrdb-ui-group {\n  background: radial-gradient(circle at top left, #1e293b, #020617) !important;\n  border: 1px solid rgba(148, 163, 184, 0.3) !important;\n  border-radius: 12px !important;\n}\n.nrdb-ui-group .v-card-title,\n.nrdb-ui-group .nrdb-ui-group-title {\n  color: #94a3b8 !important;\n  text-transform: uppercase !important;\n  letter-spacing: 0.05em !important;\n  font-size: 0.75rem !important;\n  font-weight: 600 !important;\n}\n\n/* Primary text within groups */\n.nrdb-ui-group .v-card-text { color: #e5e7eb !important; }\n\n/* Buttons — pill shape */\n.v-btn {\n  border-radius: 999px !important;\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif !important;\n  font-weight: 500 !important;\n  letter-spacing: 0.02em !important;\n}\n\n/* Switch styling */\n.v-switch .v-switch__track { opacity: 0.7 !important; }\n\n/* Text inputs — deep surface background */\n.v-field {\n  background-color: #020617 !important;\n  border-radius: 8px !important;\n}\n.v-field input { color: #e5e7eb !important; }\n.v-field--focused { border-color: #22c55e !important; }\n\n/* Labels and secondary text */\n.v-label { color: #9ca3af !important; }\n\n/* Slider thumb and track */\n.v-slider-thumb { color: #22c55e !important; }\n\n/* Notification styling */\n.v-snackbar__content {\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif !important;\n}\n\n/* Scrollbar styling */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: #020617; }\n::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 3px; }\n::-webkit-scrollbar-thumb:hover { background: #334155; }\n\n/* System font globally */\nbody, .v-application {\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif !important;\n}","storeOutMessages":false,"passthru":false,"resendOnRefresh":true,"templateScope":"global","className":"","x":400,"y":60,"wires":[[]]},
